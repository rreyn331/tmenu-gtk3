#!/bin/bash

# Path to the RAM cache created by your Python UI
CACHE_FILE="/tmp/tmenu/apps.json"

# 1. Check if the cache exists. If not, tell the user to run the main UI once.
if [ ! -f "$CACHE_FILE" ]; then
    echo "Error: Cache not found at $CACHE_FILE"
    echo "Please run your main TMenu Python app once to generate the RAM cache."
    exit 1
fi

# 2. Use fzf to create the interactive menu
# --height 15: Sets a fixed size (15 lines)
# --reverse: Puts the search box at the top
# --border: Adds a clean frame
SELECTED=$(jq -r '.[].Name' "$CACHE_FILE" | fzf \
    --height=15 \
    --reverse \
    --border \
    --prompt="🚀 Run: " \
    --header="[↑/↓] Navigate  [Enter] Launch  [Esc] Quit")

# 3. If a selection was made (user didn't hit Esc)
if [ -n "$SELECTED" ]; then
    # Extract the 'Exec' field, remove desktop placeholders like %u or %f
    EXEC=$(jq -r ".[] | select(.Name==\"$SELECTED\") | .Exec" "$CACHE_FILE" | sed 's/%[fFuU]//g')
    
    # Launch in the background (nohup prevents it from closing if you close the terminal)
    nohup $EXEC >/dev/null 2>&1 &
    
    # Optional: Brief confirmation before the script exits
    echo "Successfully launched $SELECTED"
fi